EXEC
#include <stdio.h>
#include <unistd.h>
int main() {
 printf("Before exec() - PID: %d\n", getpid());
 char *args[] = {"ls", "-l", NULL};
 execvp("ls", args);
 printf("exec failed!\n");
 return 0;
}



CLOSE
#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
int main() {
 int fd = open("sample.txt", O_CREAT | O_RDWR, 0644);
 if (fd < 0) {
 printf("File open failed!\n");
 return 1;
 }
 printf("File opened with descriptor: %d\n", fd);
 close(fd);
 printf("File closed successfully.\n");
 return 0;
}



STAT
#include <stdio.h>
#include <sys/stat.h>
int main() {
 struct stat info;
 if (stat("sample.txt", &info) < 0) {
 printf("stat failed!\n");
 return 1;
 }
 printf("File Size: %ld bytes\n", info.st_size);
 printf("Permissions: %o\n", info.st_mode & 0777);
 printf("Links: %ld\n", info.st_nlink);
 return 0;
}



OPENDIR AND READDIR
#include <stdio.h>
#include <dirent.h>
int main() {
 DIR *dir;
 struct dirent *entry;
 dir = opendir(".");
 if (dir == NULL) {
 printf("Cannot open directory.\n");
 return 1;
 }
 printf("Directory contents:\n");
 while ((entry = readdir(dir)) != NULL) {
 printf("%s\n", entry->d_name);
 }
 closedir(dir);
 return 0;
}

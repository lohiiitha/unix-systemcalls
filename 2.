#include <stdio.h>
#include <unistd.h>
#include <sys/wait.h>
#include <stdlib.h>
int main() {
 printf("Parent PID: %d\n", getpid());
 pid_t pid = fork();
 if (pid < 0) {
 printf("Fork failed!\n");
 exit(1);
 }
 else if (pid == 0) {
 printf("Child PID: %d\n", getpid());
 printf("Child exiting...\n");
 exit(0);
 }
 else {
 wait(NULL);
 printf("Parent: Child has completed.\n");
 }
 return 0;
}
